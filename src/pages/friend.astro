---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import FriendCard from "@/components/mdx/FriendCard.astro";
import Showcase from "@/components/mdx/Showcase.astro";

const friends = [
  {
    "name": "开盒",
    "avatar": "https://picbed.xiaozhangya.xin/picbed/20250726181930154.png",
    "description": "人间四月芳菲尽！",
    "url": "https://t.me/Ash662",
    "badge": "认证"
  },
  {
    "name": "代开会员",
    "avatar": "https://picbed.xiaozhangya.xin/picbed/20250726181930154.png",
    "description": "代开三个月起，六个月价格优惠！",
    "url": "https://t.me/Ash662",
    "badge": "认证"
  },
  {
    "name": "代找资源",
    "avatar": "https://picbed.xiaozhangya.xin/picbed/20250726181930154.png",
    "description": "Creazing a better world with code.",
    "url": "https://t.me/Ash662",
    "badge": "认证"
  }
];

const sites = [
  {
    "name": "在线中",
    "url": "https://t.me/Ash662"
  }
];
---

<BaseLayout title="Advertisement" isIndexed={false}>
  <!-- Advertisement Section -->
  <div class="mb-10 animate-fade-in-up">
    <h1 class="text-3xl md:text-4xl font-bold mb-4 flex items-center gap-3">
      <Icon name="lucide:users" class="text-primary" />
      <span>Friends</span>
    </h1>
    <p class="text-base-content/70 text-lg mb-6">
      本站认证。
    </p>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {friends.map((friend) => (
        <FriendCard
          name={friend.name}
          avatar={friend.avatar}
          description={friend.description}
          url={friend.url}
          badge={friend.badge}
        />
      ))}
    </div>
  </div>

  <!-- Sites Using Ryuchan Section -->
  <div class="animate-fade-in-up" style="animation-delay: 0.2s;">
    <div class="bg-base-100 rounded-3xl p-6 md:p-8 shadow-lg border border-base-200">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
        <div>
          <h2 class="text-2xl font-bold flex items-center gap-2 mb-2">
            <Icon name="lucide:layout-template" class="w-6 h-6 text-secondary" />
            <span>广告位联系</span>
          </h2>
          <p class="text-base-content/70">
            这里展示了使用 Ryuchan 主题构建的网站。
          </p>
        </div>
        <a
          href="https://t.me/Ash662"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary btn-sm gap-2"
        >
          <Icon name="lucide:plus-circle" class="w-4 h-4" />
          Add Your Site
        </a>
      </div>

      <div class="flex flex-wrap gap-4">
        {sites.map((site) => <Showcase name={site.name} url={site.url} />)}
      </div>
      
      <div class="mt-6 p-4 bg-base-200/50 rounded-2xl text-sm text-base-content/60 flex gap-2 items-start">
        <Icon name="lucide:info" class="w-5 h-5 flex-shrink-0 mt-0.5" />
        <p>
          想要将你的广告添加到这里吗？点击右上角的 "Add Your Site" 按钮，联系管理员来添加你的联系方式！
        </p>
      </div>
    </div>
  </div>

  <div class="divider my-6 animate-fade-in-up" style="animation-delay: 0.1s;">
    <Icon name="lucide:heart" class="w-12 h-12 text-primary/50" />
  </div>
</BaseLayout>